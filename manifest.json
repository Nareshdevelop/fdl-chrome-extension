{
  "manifest_version": 3,
  "name": "fivedaylaunch — SMB Website Score",
  "short_name": "fivedaylaunch",
  "description": "See the quality score (Performance, SEO, Mobile, Security, AEO) for any small business website you visit. Free, no signup.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Score this site with fivedaylaunch"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://fivedaylaunch.com/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "homepage_url": "https://fivedaylaunch.com/sites"
}
